{
  "name": "manarah-screen",
  "version": "0.1.0",
  "private": true,
  "description": "ManarahScreen — masjid monitor kiosk webapp (prayer times + event slides)",
  "scripts": {
    "dev": "concurrently -k -n server,web -c blue,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite --config web/vite.config.ts",
    "build": "npm run build:web && npm run build:server",
    "build:web": "vite build --config web/vite.config.ts",
    "build:server": "tsc -p server/tsconfig.json",
    "start": "node dist/server/index.js",
    "typecheck": "tsc -p web/tsconfig.json --noEmit && tsc -p server/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.0",
    "better-sqlite3": "^11.3.0",
    "chokidar": "^4.0.1",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.1",
    "framer-motion": "^11.11.7",
    "hijri-converter": "^1.1.1",
    "lucide-react": "^0.451.0",
    "luxon": "^3.5.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "tailwind-merge": "^2.5.3",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^5.0.0",
    "@types/luxon": "^3.4.2",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.7.5",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
